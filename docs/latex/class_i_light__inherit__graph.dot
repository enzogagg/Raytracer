digraph "ILight"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  Node1 [id="Node000001",label="ILight",height=0.2,width=0.4,color="gray40", fillcolor="grey60", style="filled", fontcolor="black",tooltip="An interface for light sources in the raytracer project."];
  Node1 -> Node2 [id="edge4_Node000001_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="AmbientLight",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_ambient_light.html",tooltip="A class to represent an ambient light source in the raytracer project."];
  Node1 -> Node3 [id="edge5_Node000001_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="DirectionalLight",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_directional_light.html",tooltip="A class to represent a directional light source in the raytracer project."];
  Node1 -> Node4 [id="edge6_Node000001_Node000004",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node4 [id="Node000004",label="PointLight",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$class_point_light.html",tooltip="A class to represent a point light source in the raytracer project."];
